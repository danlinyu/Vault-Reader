{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault Reader",
  "version": "0.1.0",
  "identifier": "local.vault-reader",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run build:web",
    "frontendDist": "../web-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vault Reader",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
